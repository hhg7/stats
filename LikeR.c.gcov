        -:  673:// Bisection algorithm to find the inverse t-distribution (Critical t-value)
        -:  674:static NV qt_tail(NV df, NV p_tail) {
        -:  675:	NV low = 0.0, high = 1.0;
        -:  676:	// Find upper bound
        -:  677:	while (get_t_pvalue(high, df, "greater") > p_tail) {
        -:  678:	  low = high;
        -:  679:	  high *= 2.0;
        -:  680:	  if (high > 1000000.0) break; /* Fallback limit */
        -:  681:	}
        -:  682:	// Bisect to find the root
        -:  683:	for (unsigned short int i = 0; i < 100; i++) {
        -:  684:	  NV mid = (low + high) / 2.0;
        -:  685:	  NV p_mid = get_t_pvalue(mid, df, "greater");
