        -:  573:	  sxy += x[i]*y[i]; sx2 += x[i]*x[i]; sy2 += y[i]*y[i];
        -:  574:	}
        -:  575:	NV num = (NV)n * sxy - sx * sy;
        -:  576:	NV den = sqrt(((NV)n * sx2 - sx*sx) * ((NV)n * sy2 - sy*sy));
        -:  577:	if (den == 0.0) return NAN;
        -:  578:	return num / den;
        -:  579:}
