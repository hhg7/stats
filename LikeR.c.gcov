        -:  686:		   low = mid;
        -:  687:	  } else {
        -:  688:		   high = mid;
        -:  689:	  }
        -:  690:	  if (high - low < 1e-8) break;
        -:  691:	}
        -:  692:	return (low + high) / 2.0;
        -:  693:}
