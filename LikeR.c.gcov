        -:  545:/* Compute 1-based average ranks with tie-breaking into out[].
        -:  546: * in[] is not modified.                                                 */
        -:  547:static void rank_data(const NV *restrict in, NV *restrict out, size_t n) {
        -:  548:	RankItem *restrict ri;
