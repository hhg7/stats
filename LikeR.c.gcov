        -:  316:/* --- General R x C exact test (used for anything that is not 2x2) ---------
        -:  317: *
        -:  318: * The 2x2 machinery above cannot describe larger tables, so the R x C case
        -:  319: * is handled by direct enumeration of every contingency table that shares
        -:  320: * the observed row and column margins.  Under the null the probability of a
        -:  321: * table T with fixed margins is the multivariate hypergeometric
        -:  322: *
        -:  323: *      P(T) = (prod_i R_i!)(prod_j C_j!) / ( N! prod_ij t_ij! )
        -:  324: *
        -:  325: * The (two-sided) p-value is the sum of P(T) over all such T whose
        -:  326: * probability is <= P(observed).  Only two-sided is defined for R x C, so
        -:  327: * 'alternative' is ignored for larger tables (matching R's fisher.test). */
        -:  328:typedef struct {
        -:  329:	int nrow, ncol;
        -:  330:	const long *restrict R;   /* fixed row totals                       */
        -:  331:	long *restrict C_rem;     /* remaining column totals (mutated)      */
        -:  332:	NV const_term;            /* sum lgamma(R_i+1)+lgamma(C_j+1)-lgamma(N+1) */
        -:  333:	NV log_p_obs_tol;         /* log P(observed) + log1p(relErr)        */
        -:  334:	NV p_total;               /* accumulated p-value                    */
        -:  335:	long long nodes, cap;     /* leaf counter + overflow guard          */
        -:  336:	int aborted;              /* set once cap is exceeded               */
        -:  337:} ft_rxc_ctx;
        -:  338:
        -:  339:static void ft_rxc_row(ft_rxc_ctx *restrict X, int row, int col, long row_rem, NV cur_lc);
        -:  340:
        -:  341:/* Finish the current row; either recurse to the next free row, or (once the
        -:  342: * last free row is placed) derive the final row from the column residuals. */
        -:  343:static void ft_rxc_after_row(ft_rxc_ctx *restrict X, int row, NV cur_lc) {
        -:  344:	if (row == X->nrow - 2) {
        -:  345:		NV lc = cur_lc;
        -:  346:		for (int j = 0; j < X->ncol; j++) lc += lgamma((NV)X->C_rem[j] + 1.0);
        -:  347:		NV logP = X->const_term - lc;
        -:  348:		if (logP <= X->log_p_obs_tol) X->p_total += exp(logP);
        -:  349:		if (++X->nodes > X->cap) X->aborted = 1;
