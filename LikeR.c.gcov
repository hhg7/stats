        -:  594:			int sy = (y[i] > y[j]) - (y[i] < y[j]);
        -:  595:			if      (sx == 0 && sy == 0) { /* joint tie — not counted */ }
        -:  596:			else if (sx == 0)            tie_x++;
        -:  597:			else if (sy == 0)            tie_y++;
