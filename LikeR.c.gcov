        -: 1715:		NV an = -i * (i - a);
        -: 1716:		b += 2.0;
        -: 1717:		d = an * d + b;
        -: 1718:		if (fabs(d) < 1e-30) d = 1e-30;
        -: 1719:		c = b + an / c;
