        -:  593:			int sy = (y[i] > y[j]) - (y[i] < y[j]);
        -:  594:			if      (sx == 0 && sy == 0) { /* joint tie — not counted */ }
        -:  595:			else if (sx == 0)            tie_x++;
        -:  596:			else if (sy == 0)            tie_y++;
