        -:  667:	if (strcmp(alt, "less") == 0) return (t < 0) ? 0.5 * prob_2tail : 1.0 - 0.5 * prob_2tail;
        -:  668:	if (strcmp(alt, "greater") == 0) return (t > 0) ? 0.5 * prob_2tail : 1.0 - 0.5 * prob_2tail;
        -:  669:	return prob_2tail;
        -:  670:}
        -:  671:
        -:  672:// Bisection algorithm to find the inverse t-distribution (Critical t-value)
        -:  673:static NV qt_tail(NV df, NV p_tail) {
        -:  674:	NV low = 0.0, high = 1.0;
        -:  675:	// Find upper bound
        -:  676:	while (get_t_pvalue(high, df, "greater") > p_tail) {
        -:  677:	  low = high;
        -:  678:	  high *= 2.0;
        -:  679:	  if (high > 1000000.0) break; /* Fallback limit */
        -:  680:	}
        -:  681:	// Bisect to find the root
        -:  682:	for (unsigned short int i = 0; i < 100; i++) {
        -:  683:	  NV mid = (low + high) / 2.0;
        -:  684:	  NV p_mid = get_t_pvalue(mid, df, "greater");
