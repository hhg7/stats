        -: 1702:			term *= x / (a + n);
        -: 1703:			sum += term;
        -: 1704:			n += 1.0;
        -: 1705:		}
        -: 1706:		return 1.0 - (sum * exp(-x + a * log(x) - lgamma(a)));
        -: 1707:	}
        -: 1708:
