        -: 2043:	  low = high;
        -: 2044:	  high *= 2.0;
        -: 2045:	  if (high > 1e100) break; /* Fallback limit */
        -: 2046:	}
        -: 2047:
        -: 2048:	// Bisect to find the root
        -: 2049:	for (unsigned short int i = 0; i < 150; i++) {
        -: 2050:		NV mid = low + (high - low) / 2.0;
        -: 2051:		NV p_mid = pf(mid, df1, df2);
        -: 2052:
        -: 2053:		if (p_mid < p) {
        -: 2054:			low = mid;
        -: 2055:		} else {
        -: 2056:			high = mid;
        -: 2057:		}
        -: 2058:		if (high - low < 1e-12) break;
        -: 2059:	}
        -: 2060:	return (low + high) / 2.0;
        -: 2061:}
