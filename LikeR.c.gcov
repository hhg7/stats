        -:  510:		   int sy = (y[i] > y[j]) - (y[i] < y[j]);
        -:  511:		   if      (sx == 0 && sy == 0) { /* joint tie — not counted */ }
        -:  512:		   else if (sx == 0)            tie_x++;
