        -: 1406:/* CRC-32/IEEE over a byte buffer (each stored ZIP member needs its checksum). */
        -: 1407:static uint32_t xlsx_crc32(const unsigned char *restrict data, size_t len) {
        -: 1408:	uint32_t table[256];
        -: 1409:	for (uint32_t i = 0; i < 256; i++) {
        -: 1410:		uint32_t c = i;
        -: 1411:		for (int k = 0; k < 8; k++)
        -: 1412:			c = (c & 1u) ? (0xEDB88320u ^ (c >> 1)) : (c >> 1);
        -: 1413:		table[i] = c;
        -: 1414:	}
        -: 1415:	uint32_t crc = 0xFFFFFFFFu;
        -: 1416:	for (size_t i = 0; i < len; i++)
        -: 1417:		crc = table[(crc ^ data[i]) & 0xFFu] ^ (crc >> 8);
        -: 1418:	return crc ^ 0xFFFFFFFFu;
        -: 1419:}
