        -:  581:/* Kendall's tau-b between two n-element arrays.
        -:  582:
        -:  583: *   tau-b = (C − D) / sqrt((C + D + T_x)(C + D + T_y))
        -:  584: *
        -:  585: * where C = concordant pairs, D = discordant, T_x = pairs tied only on
        -:  586: * x, T_y = pairs tied only on y.  Joint ties (both zero) are excluded
        -:  587: * from numerator and denominator, matching R's cor(method="kendall").
        -:  588: * Returns NAN when the denominator is zero.                             */
        -:  589:static NV kendall_tau_b(const NV *restrict x, const NV *restrict y, unsigned int n) {
