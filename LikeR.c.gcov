        -:  546:/* Compute 1-based average ranks with tie-breaking into out[].
        -:  547: * in[] is not modified.                                                 */
        -:  548:static void rank_data(const NV *restrict in, NV *restrict out, size_t n) {
        -:  549:	RankItem *restrict ri;
