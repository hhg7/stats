        -:  101:	NV step = 1.0 / n_steps;
        -:  102:	NV integral = 0.0, half_df = df / 2.0;
        -:  103:	NV log_coef = log(2.0) + half_df * log(half_df) - lgamma(half_df);
        -:  104:	NV root_half = 0.70710678118654752440; // 1 / sqrt(2)
        -:  105:	for (unsigned short i = 1; i < n_steps; i++) {
        -:  106:		NV u = i * step;
        -:  107:		NV w = u / (1.0 - u);
        -:  108:		// Scaled Chi-distribution log-density
        -:  109:		NV log_M = log_coef + (df - 1.0) * log(w) - half_df * w * w;
        -:  110:		NV M = exp(log_M);
        -:  111:		// Exact Normal CDF using the C standard library's erfc function
        -:  112:		NV z = t * w - ncp;
        -:  113:		NV pnorm_val = 0.5 * erfc(-z * root_half);
        -:  114:		NV weight = (i % 2 != 0) ? 4.0 : 2.0;
        -:  115:		integral += weight * (pnorm_val * M / ((1.0 - u) * (1.0 - u)));
        -:  116:	}
        -:  117:	return integral * (step / 3.0);
        -:  118:}
