        -:  101:	for (unsigned short i = 1; i < n_steps; i++) {
        -:  102:		NV u = i * step;
        -:  103:		NV w = u / (1.0 - u);
        -:  104:		// Scaled Chi-distribution log-density
        -:  105:		NV log_M = log_coef + (df - 1.0) * log(w) - half_df * w * w;
        -:  106:		NV M = exp(log_M);
        -:  107:		// Exact Normal CDF using the C standard library's erfc function
        -:  108:		NV z = t * w - ncp;
        -:  109:		NV pnorm_val = 0.5 * erfc(-z * root_half);
        -:  110:		NV weight = (i % 2 != 0) ? 4.0 : 2.0;
        -:  111:		integral += weight * (pnorm_val * M / ((1.0 - u) * (1.0 - u)));
        -:  112:	}
        -:  113:	return integral * (step / 3.0);
        -:  114:}
