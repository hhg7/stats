diff a/LikeR.xs b/LikeR.xs	(rejected hunks)
@@ -2329,9 +2329,292 @@ static long bt_check_count(pTHX_ SV *sv, const char *what) {
 		croak("binom_test: %s must be a nonnegative integer", what);
