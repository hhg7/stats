typeof(lm_mtcars)
for (i in seq_along(fitted)) {
  name  <- names(fitted)[i]
  value <- fitted[i]
  
  # Escape any single quotes in the name (very rare for car names, but safe)
  name_esc <- gsub("'", "\\\\'", name)
  
  # Print with the same decimal precision you showed (adjust %.5f if you want more/less)
  cat(sprintf("    '%s' => %.5f,\n", name_esc, value))
}
